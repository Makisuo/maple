{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "DOCKERFILE",
		"dockerfilePath": "Dockerfile.self-managed",
		"watchPatterns": ["Dockerfile.self-managed", "supervisor.mjs", "collector-self-managed-config.yaml"]
	},
	"deploy": {
		"healthcheckPath": "/-/health",
		"restartPolicyType": "ALWAYS"
	}
}
