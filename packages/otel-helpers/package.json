{
	"name": "@maple/otel-helpers",
	"version": "0.1.0",
	"description": "Tiny OpenTelemetry helpers for Maple — withSpan() for bounded business spans without try/catch/finally bloat.",
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"src/**/*.ts",
