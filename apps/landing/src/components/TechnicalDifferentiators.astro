---
import * as m from "../paraglide/messages";
---

<section class="pt-12 pb-16 md:pt-16 md:pb-24 lg:pt-20 lg:pb-32">
    <div class="mx-auto max-w-6xl px-6">
        <div class="mb-12">
            <span class="text-[11px] text-accent uppercase tracking-wider">{m.tech_badge()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg">{m.tech_heading()}</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border">
            <!-- Columnar storage -->
            <div class="bg-bg p-6 md:p-8">
                <h3 class="text-base font-semibold text-fg mb-2">{m.tech_columnar_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed mb-6">
                    {m.tech_columnar_desc()}
                </p>
                <div class="bg-bg-elevated border border-border p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <span class="text-[9px] text-fg-muted ml-2">query</span>
                    </div>
                    <code class="text-[10px] text-chart-1 block leading-relaxed">
                        <span class="text-fg-muted">SELECT</span> avg(duration)<br />
                        <span class="text-fg-muted">FROM</span> spans<br />
                        <span class="text-fg-muted">WHERE</span> service = <span class="text-chart-2">'api'</span>
                    </code>
                    <div class="mt-3 pt-3 border-t border-border flex items-center justify-between">
                        <span class="text-[9px] text-fg-muted">{m.tech_columnar_rows()}</span>
                        <span class="text-[9px] text-chart-2 font-medium">12ms</span>
                    </div>
                </div>
            </div>

            <!-- Correlated signals -->
            <div class="bg-bg p-6 md:p-8">
                <h3 class="text-base font-semibold text-fg mb-2">{m.tech_correlated_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed mb-6">
                    {m.tech_correlated_desc()}
                </p>
                <div class="bg-bg-elevated border border-border p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <span class="text-[9px] text-fg-muted ml-2">correlation</span>
                    </div>
                    <div class="space-y-2">
                        <div class="flex items-center gap-3">
                            <div class="w-16 text-[9px] text-chart-1 border border-chart-1/30 bg-chart-1/5 px-2 py-1 text-center">{m.tech_trace()}</div>
                            <div class="flex-1 border-t border-dashed border-border"></div>
                            <svg class="w-3 h-3 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-16 text-[9px] text-chart-2 border border-chart-2/30 bg-chart-2/5 px-2 py-1 text-center">{m.tech_log()}</div>
                            <div class="flex-1 border-t border-dashed border-border"></div>
                            <svg class="w-3 h-3 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-16 text-[9px] text-chart-3 border border-chart-3/30 bg-chart-3/5 px-2 py-1 text-center">{m.tech_metric()}</div>
                            <div class="flex-1 border-t border-dashed border-border"></div>
                            <svg class="w-3 h-3 text-fg-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                    </div>
                    <div class="mt-3 pt-3 border-t border-border">
                        <span class="text-[9px] text-fg-muted">trace_id: </span>
                        <span class="text-[9px] text-accent font-mono">a1b2c3d4e5f6</span>
                    </div>
                </div>
            </div>

            <!-- Real-time ingestion -->
            <div class="bg-bg p-6 md:p-8">
                <h3 class="text-base font-semibold text-fg mb-2">{m.tech_realtime_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed mb-6">
                    {m.tech_realtime_desc()}
                </p>
                <div class="bg-bg-elevated border border-border p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <span class="text-[9px] text-fg-muted ml-2">ingestion</span>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] text-fg-muted">{m.tech_status()}</span>
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 bg-green-400 animate-pulse-dot"></div>
                                <span class="text-[9px] text-green-400">{m.tech_live()}</span>
                            </div>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] text-fg-muted">{m.tech_last_span()}</span>
                            <span class="text-[9px] text-fg font-mono">{m.tech_last_span_value()}</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] text-fg-muted">{m.tech_ingestion_rate()}</span>
                            <span class="text-[9px] text-fg font-mono">14.2K/s</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] text-fg-muted">{m.tech_avg_latency()}</span>
                            <span class="text-[9px] text-fg font-mono">1.8s</span>
                        </div>
                    </div>
                    <div class="mt-3 pt-3 border-t border-border">
                        <div class="flex items-end gap-[1px] h-6">
                            <div class="flex-1 bg-chart-2/40 h-[50%]"></div>
                            <div class="flex-1 bg-chart-2/45 h-[60%]"></div>
                            <div class="flex-1 bg-chart-2/50 h-[55%]"></div>
                            <div class="flex-1 bg-chart-2/55 h-[70%]"></div>
                            <div class="flex-1 bg-chart-2/60 h-[65%]"></div>
                            <div class="flex-1 bg-chart-2/65 h-[80%]"></div>
                            <div class="flex-1 bg-chart-2/70 h-[75%]"></div>
                            <div class="flex-1 bg-chart-2/75 h-[85%]"></div>
                            <div class="flex-1 bg-chart-2/80 h-[90%]"></div>
                            <div class="flex-1 bg-chart-2 h-[95%]"></div>
                            <div class="flex-1 bg-chart-2 h-[88%]"></div>
                            <div class="flex-1 bg-chart-2 h-[92%]"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Connectors note -->
        <div class="mt-px border border-border bg-bg p-4 md:p-6 flex flex-col md:flex-row items-start md:items-center gap-4">
            <div class="flex-1">
                <h3 class="text-sm font-semibold text-fg">{m.tech_connectors_title()}</h3>
                <p class="text-[11px] text-fg-muted mt-1 leading-relaxed">{m.tech_connectors_desc()}</p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
                <div class="flex items-center gap-2 border border-border px-3 py-1.5">
                    <img src="https://cdn.brandfetch.io/cloudflare.com/w/48/h/48/theme/dark/icon.jpeg" alt="Cloudflare" class="w-4 h-4 grayscale opacity-60" loading="lazy" />
                    <span class="text-[9px] text-fg-muted font-mono">Logpush</span>
                </div>
                <div class="flex items-center gap-2 border border-border px-3 py-1.5">
                    <img src="https://cdn.brandfetch.io/prometheus.io/w/48/h/48/theme/dark/icon.jpeg" alt="Prometheus" class="w-4 h-4 grayscale opacity-60" loading="lazy" />
                    <span class="text-[9px] text-fg-muted font-mono">Scrape</span>
                </div>
            </div>
        </div>
    </div>
</section>
