---
const uid = Math.random().toString(36).slice(2, 8);

// ─── Service map geometry (mock-view-map) ──────────────────────────────
// Pixel-faithful copy of apps/web/src/components/service-map/ServiceMapNode.tsx.
// Same 220×62 card, same Tailwind classes, same brand-icon SVGs, same
// severity colors. Edges keep the dashboard's smoothstep + flowing-dash
// vocabulary. Rendered as static HTML inside SVG <foreignObject> so the
// whole canvas scales with the mock window via the SVG viewBox.
type Platform = "kubernetes" | "cloudflare" | "lambda" | undefined;
type DbSystem = "postgres" | "redis" | "clickhouse" | "mysql" | "mongodb" | undefined;

interface MapNode {
    id: string;
    label: string;
    col: number;
    row: number;
    hot?: boolean;
    db?: boolean;
    dbSystem?: DbSystem;
    platform?: Platform;
    rps: string;
    rpsPrefix?: string;
    err?: string;
    avg: string;
    pods?: number;
}
interface MapEdge { from: string; to: string; rps?: number; calls: string; hot?: boolean }

const MAP_NODE_W = 220;
const MAP_NODE_H = 62;
const MAP_COL_X = [10, 270, 530, 790];
const MAP_ROWS_PER_COL: number[][] = [
    [180],
    [180],
    [80, 180, 280],
    [110, 250],
];

const mapNodes: MapNode[] = [
    { id: "edge",     label: "edge",         col: 0, row: 0, platform: "cloudflare", rps: "12.4k", err: "0.1", avg: "8ms",   pods: 6  },
    { id: "checkout", label: "checkout-api", col: 1, row: 0, platform: "kubernetes", rps: "4.2k",  err: "0.3", avg: "24ms",  pods: 12 },
    { id: "auth",     label: "auth-svc",     col: 2, row: 0, platform: "kubernetes", rps: "4.2k",  err: "0.0", avg: "6ms",   pods: 8  },
    { id: "pricing",  label: "pricing",      col: 2, row: 1, platform: "kubernetes", hot: true, rps: "2.8k", err: "2.4", avg: "142ms", pods: 4 },
    { id: "payments", label: "payments",     col: 2, row: 2, platform: "lambda",     rps: "1.1k",  err: "0.5", avg: "38ms" },
    { id: "redis",    label: "redis",        col: 3, row: 0, db: true, dbSystem: "redis",    rps: "18.2k", avg: "2ms"  },
    { id: "postgres", label: "postgres",     col: 3, row: 1, db: true, dbSystem: "postgres", rps: "6.4k",  avg: "14ms" },
];

const mapEdges: MapEdge[] = [
    { from: "edge",     to: "checkout", rps: 4200,  calls: "4.2k"  },
    { from: "checkout", to: "auth",     rps: 4200,  calls: "4.2k"  },
    { from: "checkout", to: "pricing",  rps: 2800,  calls: "2.8k", hot: true },
    { from: "checkout", to: "payments", rps: 1100,  calls: "1.1k" },
    { from: "pricing",  to: "redis",    rps: 12400, calls: "12.4k" },
    { from: "pricing",  to: "postgres", rps: 6400,  calls: "6.4k"  },
];

// Service-color slot (matches packages/ui/src/lib/colors.ts: hash idx → --service-N)
const mapOrderedServices = Array.from(new Set(mapNodes.filter((n) => !n.db).map((n) => n.label)));
function mapServiceColor(label: string): string {
    const idx = (mapOrderedServices.indexOf(label) % 16) + 1;
    return `var(--service-${idx})`;
}

interface Pt { x: number; y: number }
const mapNodeRight = (n: MapNode): Pt => ({ x: MAP_COL_X[n.col] + MAP_NODE_W, y: MAP_ROWS_PER_COL[n.col][n.row] });
const mapNodeLeft  = (n: MapNode): Pt => ({ x: MAP_COL_X[n.col],              y: MAP_ROWS_PER_COL[n.col][n.row] });

function smoothStepPath(a: Pt, b: Pt, r = 12): string {
    if (Math.abs(a.y - b.y) < 0.5) return `M ${a.x} ${a.y} L ${b.x} ${b.y}`;
    const midX = (a.x + b.x) / 2;
    const dy = Math.sign(b.y - a.y);
    return [
        `M ${a.x} ${a.y}`,
        `L ${midX - r} ${a.y}`,
        `Q ${midX} ${a.y} ${midX} ${a.y + dy * r}`,
        `L ${midX} ${b.y - dy * r}`,
        `Q ${midX} ${b.y} ${midX + r} ${b.y}`,
        `L ${b.x} ${b.y}`,
    ].join(" ");
}

// Match the dashboard formula: clamp(2, 8, 2 + log10(callCount) * 2)
function strokeWidthFor(callCount: number | undefined): number {
    if (!callCount || callCount <= 0) return 2;
    return Math.min(8, Math.max(2, 2 + Math.log10(callCount) * 2));
}

const mapNodeById = Object.fromEntries(mapNodes.map((n) => [n.id, n]));
const mapEdgeRender = mapEdges.map((e, i) => {
    const fromNode = mapNodeById[e.from];
    const toNode = mapNodeById[e.to];
    const a = mapNodeRight(fromNode);
    const b = mapNodeLeft(toNode);
    const midX = (a.x + b.x) / 2;
    const labelY = a.y + (b.y - a.y) / 2;
    return {
        ...e,
        gradId: `mockmap-${uid}-${i}`,
        path: smoothStepPath(a, b),
        sw: strokeWidthFor(e.rps),
        sourceColor: mapServiceColor(fromNode.label),
        targetColor: toNode.db ? "var(--severity-info)" : mapServiceColor(toNode.label),
        sourcePt: a,
        targetPt: b,
        labelX: midX,
        labelY,
    };
});

const MAP_VIEW_W = 1020;
const MAP_VIEW_H = 360;
---

<div class="app-mock border border-border bg-bg-elevated overflow-hidden">
    <!-- Window chrome -->
    <div class="flex items-center gap-2 px-4 py-2 border-b border-border bg-bg">
        <div class="w-2.5 h-2.5 bg-border"></div>
        <div class="w-2.5 h-2.5 bg-border"></div>
        <div class="w-2.5 h-2.5 bg-border"></div>
        <span class="ml-3 text-fg-muted text-[10px]">maple.dev</span>
    </div>

    <!-- Hidden radio inputs for tab switching -->
    <input type="radio" name={`mock-nav-${uid}`} id={`mock-map-${uid}`} class="mock-radio mock-radio-map" checked />
    <input type="radio" name={`mock-nav-${uid}`} id={`mock-overview-${uid}`} class="mock-radio mock-radio-overview" />
    <input type="radio" name={`mock-nav-${uid}`} id={`mock-services-${uid}`} class="mock-radio mock-radio-services" />
    <input type="radio" name={`mock-nav-${uid}`} id={`mock-traces-${uid}`} class="mock-radio mock-radio-traces" />
    <input type="radio" name={`mock-nav-${uid}`} id={`mock-logs-${uid}`} class="mock-radio mock-radio-logs" />
    <input type="radio" name={`mock-nav-${uid}`} id={`mock-metrics-${uid}`} class="mock-radio mock-radio-metrics" />

    <div class="flex min-h-[340px] md:min-h-[400px]">
        <!-- Sidebar -->
        <div class="w-40 border-r border-border shrink-0 hidden md:flex flex-col bg-bg">
            <div class="flex items-center gap-2 px-3 py-3 border-b border-border">
                <div class="w-5 h-5 bg-accent flex items-center justify-center">
                    <span class="text-accent-foreground text-[9px] font-bold">M</span>
                </div>
                <span class="text-fg text-[11px] font-medium">Maple</span>
            </div>
            <div class="p-2 text-[9px] text-fg-muted uppercase tracking-wider px-3 pt-3">Navigation</div>
            <nav class="px-1.5 space-y-0.5 flex-1">
                <label for={`mock-map-${uid}`} class="mock-nav-map mock-nav-item flex items-center gap-2 px-2 py-1.5 cursor-pointer text-[10px] text-fg-muted hover:text-fg transition-colors">
                    <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><circle cx="12" cy="12" r="2"/><line x1="7" y1="6" x2="10" y2="11"/><line x1="17" y1="6" x2="14" y2="11"/><line x1="7" y1="18" x2="10" y2="13"/><line x1="17" y1="18" x2="14" y2="13"/></svg>
                    Service Map
                </label>
                <label for={`mock-overview-${uid}`} class="mock-nav-overview mock-nav-item flex items-center gap-2 px-2 py-1.5 cursor-pointer text-[10px] text-fg-muted hover:text-fg transition-colors">
                    <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                    Overview
                </label>
                <label for={`mock-services-${uid}`} class="mock-nav-services mock-nav-item flex items-center gap-2 px-2 py-1.5 cursor-pointer text-[10px] text-fg-muted hover:text-fg transition-colors">
                    <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="0"/><rect x="2" y="14" width="20" height="8" rx="0"/><circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/></svg>
                    Services
                </label>
                <label for={`mock-traces-${uid}`} class="mock-nav-traces mock-nav-item flex items-center gap-2 px-2 py-1.5 cursor-pointer text-[10px] text-fg-muted hover:text-fg transition-colors">
                    <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
                    Traces
                </label>
                <label for={`mock-logs-${uid}`} class="mock-nav-logs mock-nav-item flex items-center gap-2 px-2 py-1.5 cursor-pointer text-[10px] text-fg-muted hover:text-fg transition-colors">
                    <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Logs
                </label>
                <label for={`mock-metrics-${uid}`} class="mock-nav-metrics mock-nav-item flex items-center gap-2 px-2 py-1.5 cursor-pointer text-[10px] text-fg-muted hover:text-fg transition-colors">
                    <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    Metrics
                </label>
            </nav>
        </div>

        <!-- ===== SERVICE MAP VIEW ===== -->
        <div class="mock-view mock-view-map flex-1 p-3 md:p-4 space-y-3 overflow-hidden">
            <!-- Header -->
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-[9px] text-fg-muted">Service Map</div>
                    <div class="text-xs text-fg font-medium">Live dependencies</div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-[9px] text-fg-muted border border-border px-2 py-0.5">production</span>
                    <span class="inline-flex items-center gap-1.5 text-[9px] text-primary border border-border px-2 py-0.5">
                        <span class="size-1 rounded-full bg-primary animate-pulse-dot"></span>
                        live · 60s
                    </span>
                </div>
            </div>

            <!-- Map canvas. SVG handles scaling via viewBox; nodes ride along
                 inside <foreignObject> so they use the dashboard's exact Tailwind
                 markup (matches apps/web/src/components/service-map/ServiceMapNode.tsx). -->
            <div class="relative border border-border bg-card overflow-hidden">
                <svg
                    viewBox={`0 0 ${MAP_VIEW_W} ${MAP_VIEW_H}`}
                    class="block w-full h-auto"
                    role="img"
                    aria-label="Live service dependency graph"
                >
                    <defs>
                        <!-- React Flow's BackgroundVariant.Dots: gap 16, size 1 -->
                        <pattern id={`mockmap-dots-${uid}`} x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
                            <circle cx="0.5" cy="0.5" r="0.5" fill="color-mix(in oklab, var(--muted-foreground) 30%, transparent)" />
                        </pattern>
                        <!-- userSpaceOnUse so the filter region doesn't collapse on horizontal
                             (zero-bbox-height) paths — keeps every edge visually consistent. -->
                        <filter id={`mockmap-ambient-${uid}`} filterUnits="userSpaceOnUse" x="0" y="0" width={MAP_VIEW_W} height={MAP_VIEW_H}>
                            <feGaussianBlur in="SourceGraphic" stdDeviation="8" />
                        </filter>
                        <filter id={`mockmap-glass-${uid}`} filterUnits="userSpaceOnUse" x="0" y="0" width={MAP_VIEW_W} height={MAP_VIEW_H}>
                            <feGaussianBlur in="SourceGraphic" stdDeviation="0.5" result="glass-blur" />
                            <feMerge>
                                <feMergeNode in="glass-blur" />
                                <feMergeNode in="SourceGraphic" />
                            </feMerge>
                        </filter>
                        {mapEdgeRender.map((e) => (
                            <linearGradient id={e.gradId} gradientUnits="userSpaceOnUse"
                                x1={e.sourcePt.x} y1={e.sourcePt.y}
                                x2={e.targetPt.x} y2={e.targetPt.y}>
                                <stop offset="0%" stop-color={e.sourceColor} />
                                <stop offset="100%" stop-color={e.targetColor} />
                            </linearGradient>
                        ))}
                    </defs>

                    <!-- Dot grid background -->
                    <rect x="0" y="0" width={MAP_VIEW_W} height={MAP_VIEW_H} fill={`url(#mockmap-dots-${uid})`} />

                    <!-- Edges: 5 layers (ambient, tube wall, dark core, glass, flowing dashes) — matches ServiceMapEdge.tsx -->
                    {mapEdgeRender.map((e) => {
                        const intensity = e.rps && e.rps > 0 ? Math.min(1, 0.3 + 0.7 * (Math.log10(1 + e.rps) / Math.log10(100))) : 0.15;
                        return (
                            <g>
                                <path d={e.path} fill="none" stroke={`url(#${e.gradId})`} stroke-width={e.sw * 3 + 12} stroke-opacity={0.04 + intensity * 0.08} filter={`url(#mockmap-ambient-${uid})`} />
                                <path d={e.path} fill="none" stroke={`url(#${e.gradId})`} stroke-width={e.sw + 4} stroke-opacity={0.12 + intensity * 0.15} />
                                <path d={e.path} fill="none" stroke="oklch(0.141 0.005 285.823)" stroke-width={e.sw} stroke-opacity={0.5 + intensity * 0.2} />
                                <path d={e.path} fill="none" stroke={`url(#${e.gradId})`} stroke-width={e.sw * 0.4} stroke-opacity={0.15 + intensity * 0.25} filter={`url(#mockmap-glass-${uid})`} />
                                <path d={e.path} fill="none" stroke={`url(#${e.gradId})`} stroke-width={e.sw * 0.25} stroke-opacity={0.2 + intensity * 0.4} stroke-dasharray="4 20" class="svc-map-flow" />
                            </g>
                        );
                    })}

                    <!-- Nodes — exact ServiceMapNode.tsx markup inside foreignObject -->
                    {mapNodes.map((n) => {
                        const x = MAP_COL_X[n.col];
                        const y = MAP_ROWS_PER_COL[n.col][n.row] - MAP_NODE_H / 2;
                        const errNum = n.err ? parseFloat(n.err) : 0;
                        const healthDotCls = errNum > 5 ? "bg-severity-error" : errNum > 1 ? "bg-severity-warn" : "bg-severity-info";
                        const errCls = errNum > 5 ? "text-severity-error" : errNum > 1 ? "text-severity-warn" : "text-fg";
                        const cardBorderCls = n.hot ? "border-severity-warn" : "border-border";
                        const cardBgCls = n.db ? "bg-muted/40" : "bg-card";
                        const accent = n.db ? "var(--severity-info)" : mapServiceColor(n.label);
                        return (
                            <foreignObject x={x} y={y} width={MAP_NODE_W} height={MAP_NODE_H} class="overflow-visible">
                                <div xmlns="http://www.w3.org/1999/xhtml" class={`w-[220px] rounded-lg border overflow-hidden flex ${cardBgCls} ${cardBorderCls}`} style={n.hot ? "box-shadow: 0 0 0 3px color-mix(in oklab, var(--severity-warn) 15%, transparent);" : undefined}>
                                    {/* Left accent stripe */}
                                    <div class="w-[3px] shrink-0" style={`background-color: ${accent}`}></div>

                                    <div class="flex flex-col gap-2 px-3 py-2.5 flex-1 min-w-0">
                                        {/* Header: health dot · platform/db icon · service name · DB badge */}
                                        <div class="flex items-center gap-1.5">
                                            <div class={`h-1.5 w-1.5 rounded-full shrink-0 ${healthDotCls}`}></div>
                                            {/* Platform / DB icon — inline SVG, brand colors */}
                                            {n.platform === "kubernetes" && (
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#326CE5" class="shrink-0" aria-hidden="true">
                                                    <path d="M10.204 14.35l.007.01-.999 2.413a5.171 5.171 0 0 1-2.075-2.597l2.578-.437.004.005a.44.44 0 0 1 .484.606zm-.833-2.129a.44.44 0 0 0 .173-.756l.002-.011L7.585 9.7a5.143 5.143 0 0 0-.73 3.255l2.514-.725.002-.009zm1.145-1.98a.44.44 0 0 0 .699-.337l.01-.005.15-2.62a5.144 5.144 0 0 0-3.01 1.442l2.147 1.523.004-.002zm.76 2.75l.723.349.722-.347.18-.78-.5-.623h-.804l-.5.623.179.779zm1.5-3.095a.44.44 0 0 0 .7.336l.008.003 2.134-1.513a5.188 5.188 0 0 0-2.992-1.442l.148 2.615.002.001zm10.876 5.97l-5.773 7.181a1.6 1.6 0 0 1-1.248.594l-9.261.003a1.6 1.6 0 0 1-1.247-.596l-5.776-7.18a1.583 1.583 0 0 1-.307-1.34L2.1 5.573c.108-.47.425-.864.863-1.073L11.305.513a1.606 1.606 0 0 1 1.385 0l8.345 3.985c.438.209.755.604.863 1.073l2.062 8.955c.108.47-.005.963-.308 1.34zm-3.289-2.057c-.042-.01-.103-.026-.145-.034-.174-.033-.315-.025-.479-.038-.35-.037-.638-.067-.895-.148-.105-.04-.18-.165-.216-.216l-.201-.059a6.45 6.45 0 0 0-.105-2.332 6.465 6.465 0 0 0-.936-2.163c.052-.047.15-.133.177-.159.008-.09.001-.183.094-.282.197-.185.444-.338.743-.522.142-.084.273-.137.415-.242.032-.024.076-.062.11-.089.24-.191.295-.52.123-.736-.172-.216-.506-.236-.745-.045-.034.027-.08.062-.111.088-.134.116-.217.23-.33.35-.246.25-.45.458-.673.609-.097.056-.239.037-.303.033l-.19.135a6.545 6.545 0 0 0-4.146-2.003l-.012-.223c-.065-.062-.143-.115-.163-.25-.022-.268.015-.557.057-.905.023-.163.061-.298.068-.475.001-.04-.001-.099-.001-.142 0-.306-.224-.555-.5-.555-.275 0-.499.249-.499.555l.001.014c0 .041-.002.092 0 .128.006.177.044.312.067.475.042.348.078.637.056.906a.545.545 0 0 1-.162.258l-.012.211a6.424 6.424 0 0 0-4.166 2.003 8.373 8.373 0 0 1-.18-.128c-.09.012-.18.04-.297-.029-.223-.15-.427-.358-.673-.608-.113-.12-.195-.234-.329-.349-.03-.026-.077-.062-.111-.088a.594.594 0 0 0-.348-.132.481.481 0 0 0-.398.176c-.172.216-.117.546.123.737l.007.005.104.083c.142.105.272.159.414.242.299.185.546.338.743.522.076.082.09.226.1.288l.16.143a6.462 6.462 0 0 0-1.02 4.506l-.208.06c-.055.072-.133.184-.215.217-.257.081-.546.11-.895.147-.164.014-.305.006-.48.039-.037.007-.09.02-.133.03l-.004.002-.007.002c-.295.071-.484.342-.423.608.061.267.349.429.645.365l.007-.001.01-.003.129-.029c.17-.046.294-.113.448-.172.33-.118.604-.217.87-.256.112-.009.23.069.288.101l.217-.037a6.5 6.5 0 0 0 2.88 3.596l-.09.218c.033.084.069.199.044.282-.097.252-.263.517-.452.813-.091.136-.185.242-.268.399-.02.037-.045.095-.064.134-.128.275-.034.591.213.71.248.12.556-.007.69-.282v-.002c.02-.039.046-.09.062-.127.07-.162.094-.301.144-.458.132-.332.205-.68.387-.897.05-.06.13-.082.215-.105l.113-.205a6.453 6.453 0 0 0 4.609.012l.106.192c.086.028.18.042.256.155.136.232.229.507.342.84.05.156.074.295.145.457.016.037.043.09.062.129.133.276.442.402.69.282.247-.118.341-.435.213-.71-.02-.039-.045-.096-.065-.134-.083-.156-.177-.261-.268-.398-.19-.296-.346-.541-.443-.793-.04-.13.007-.21.038-.294-.018-.022-.059-.144-.083-.202a6.499 6.499 0 0 0 2.88-3.622c.064.01.176.03.213.038.075-.05.144-.114.28-.104.266.039.54.138.87.256.154.06.277.128.448.173.036.01.088.019.13.028l.009.003.007.001c.297.064.584-.098.645-.365.06-.266-.128-.537-.423-.608zM16.4 9.701l-1.95 1.746v.005a.44.44 0 0 0 .173.757l.003.01 2.526.728a5.199 5.199 0 0 0-.108-1.674A5.208 5.208 0 0 0 16.4 9.7zm-4.013 5.325a.437.437 0 0 0-.404-.232.44.44 0 0 0-.372.233h-.002l-1.268 2.292a5.164 5.164 0 0 0 3.326.003l-1.27-2.296h-.01zm1.888-1.293a.44.44 0 0 0-.27.036.44.44 0 0 0-.214.572l-.003.004 1.01 2.438a5.15 5.15 0 0 0 2.081-2.615l-2.6-.44-.004.005z" />
                                                </svg>
                                            )}
                                            {n.platform === "cloudflare" && (
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#F38020" class="shrink-0" aria-hidden="true">
