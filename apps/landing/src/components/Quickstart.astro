const snippets: Snippet[] = [
	{
		id: "nodejs",
		label: "Node.js",
		filename: "tracing.ts",
		descriptor: "Express, Fastify, Hono",
		lang: "ts",
		installLang: "bash",
		install: `npm install @opentelemetry/sdk-node \\
  @opentelemetry/auto-instrumentations-node \\
  @opentelemetry/exporter-trace-otlp-http \\
  @opentelemetry/exporter-logs-otlp-http`,
		instrument: fill(`// tracing.ts — run with: node --import ./tracing.ts app.ts
import { NodeSDK } from "@opentelemetry/sdk-node";
import { getNodeAutoInstrumentations } from "@opentelemetry/auto-instrumentations-node";
import { OTLPTraceExporter } from "@opentelemetry/exporter-trace-otlp-http";
import { OTLPLogExporter } from "@opentelemetry/exporter-logs-otlp-http";
import { SimpleLogRecordProcessor } from "@opentelemetry/sdk-logs";

const sdk = new NodeSDK({
  traceExporter: new OTLPTraceExporter({
    url: "{{INGEST_URL}}/v1/traces",
    headers: { Authorization: "Bearer {{API_KEY}}" },
  }),
  logRecordProcessors: [
    new SimpleLogRecordProcessor(
      new OTLPLogExporter({
        url: "{{INGEST_URL}}/v1/logs",
        headers: { Authorization: "Bearer {{API_KEY}}" },
      })
    ),
  ],
  instrumentations: [getNodeAutoInstrumentations()],
});

sdk.start();`),
	},
	{
		id: "nextjs",
		label: "Next.js",
		filename: "instrumentation.ts",
		descriptor: "App Router, Pages Router",
		lang: "ts",
		installLang: "bash",
		install: `npm install @vercel/otel @opentelemetry/sdk-logs @opentelemetry/exporter-logs-otlp-http`,
		instrument: fill(`// instrumentation.ts (project root)
import { registerOTel } from "@vercel/otel";
import { OTLPLogExporter } from "@opentelemetry/exporter-logs-otlp-http";
import { SimpleLogRecordProcessor } from "@opentelemetry/sdk-logs";

export function register() {
  registerOTel({
    serviceName: "my-next-app",
    attributes: { environment: "production" },
    traceExporter: { url: "{{INGEST_URL}}/v1/traces" },
    logRecordProcessor: new SimpleLogRecordProcessor(
      new OTLPLogExporter({
        url: "{{INGEST_URL}}/v1/logs",
        headers: { Authorization: "Bearer {{API_KEY}}" },
      })
    ),
  });
}`),
	},
	{
		id: "python",
		label: "Python",
		filename: "tracing.py",
		descriptor: "FastAPI, Django, Flask",
		lang: "python",
		installLang: "bash",
		install: `pip install opentelemetry-sdk \\
  opentelemetry-exporter-otlp-proto-http \\
  opentelemetry-instrumentation`,
		instrument: fill(`# tracing.py
from opentelemetry import trace
from opentelemetry.sdk.trace import TracerProvider
from opentelemetry.sdk.trace.export import BatchSpanProcessor
from opentelemetry.exporter.otlp.proto.http.trace_exporter import OTLPSpanExporter

provider = TracerProvider()
exporter = OTLPSpanExporter(
    endpoint="{{INGEST_URL}}/v1/traces",
    headers={"Authorization": "Bearer {{API_KEY}}"},
)
provider.add_span_processor(BatchSpanProcessor(exporter))
trace.set_tracer_provider(provider)

tracer = trace.get_tracer("quickstart")
with tracer.start_as_current_span("hello-maple"):
    print("Trace sent!")`),
	},
	{
		id: "go",
		label: "Go",
		filename: "main.go",
		descriptor: "net/http, Echo, Gin",
		lang: "go",
		installLang: "bash",
		install: `go get go.opentelemetry.io/otel \\
  go.opentelemetry.io/otel/sdk \\
  go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp`,
		instrument: fill(`package main

import (
	"context"
	"log"

	"go.opentelemetry.io/otel"
	"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp"
	"go.opentelemetry.io/otel/sdk/trace"
)

func main() {
	ctx := context.Background()

	exporter, err := otlptracehttp.New(ctx,
		otlptracehttp.WithEndpointURL("{{INGEST_URL}}/v1/traces"),
		otlptracehttp.WithHeaders(map[string]string{
			"Authorization": "Bearer {{API_KEY}}",
		}),
	)
	if err != nil {
		log.Fatal(err)
	}

	tp := trace.NewTracerProvider(trace.WithBatcher(exporter))
	defer tp.Shutdown(ctx)
	otel.SetTracerProvider(tp)

	tracer := otel.Tracer("quickstart")
	_, span := tracer.Start(ctx, "hello-maple")
	span.End()
	tp.ForceFlush(ctx)

	log.Println("Trace sent!")
}`),
	},
	{
		id: "effect",
		label: "Effect",
		filename: "telemetry.ts",
		descriptor: "Effect-TS apps",
		lang: "ts",
		installLang: "bash",
		install: `npm install @maple-dev/effect-sdk effect`,
		instrument: fill(`// telemetry.ts
import { Maple } from "@maple-dev/effect-sdk"
import { Effect } from "effect"

// Auto-detects MAPLE_ENDPOINT, MAPLE_INGEST_KEY,
// commit SHA, and deployment environment from env vars
const TracerLive = Maple.layer({
  serviceName: "my-effect-app",
})

const program = Effect.gen(function* () {
  yield* Effect.log("Hello from Effect!")
}).pipe(Effect.withSpan("hello-maple"))

Effect.runPromise(
  program.pipe(Effect.provide(TracerLive))
)`),
	},
	{
		id: "otel",
		label: "Custom",
		filename: ".env",
		descriptor: "Any OTel-compliant SDK",
		lang: "bash",
		installLang: "bash",
		install: `# Use your language's OpenTelemetry SDK
# https://opentelemetry.io/docs/languages/`,
		instrument: fill(`# Configure via environment variables — works with any OTel SDK
export OTEL_EXPORTER_OTLP_ENDPOINT="{{INGEST_URL}}"
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer {{API_KEY}}"
export OTEL_SERVICE_NAME="my-service"

# Then run your application with your language's OTel SDK enabled`),
	},
];

const defaultId = snippets[0].id;
---

<section class="relative bg-bg">
	<div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
		<div class="flex flex-wrap items-baseline justify-between gap-4 mb-4">
			<div class="text-[10px] uppercase tracking-[0.18em] text-fg-muted">{m.start_eyebrow()}</div>
			<div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-[11px] font-mono">
				<span class="text-fg-muted uppercase tracking-wider text-[10px] font-sans">{m.start_endpoint_label()}</span>
				<span class="inline-flex items-center gap-1.5 text-fg">
					<span class="relative inline-flex size-1.5" aria-hidden="true">
						<span class="absolute inset-0 rounded-full bg-primary animate-ping opacity-75"></span>
						<span class="relative inline-flex size-1.5 rounded-full bg-primary"></span>
					</span>
					{INGEST_URL}
				</span>
				<span class="text-fg-muted uppercase tracking-wider text-[10px] font-sans">{m.start_key_label()}</span>
				<span class="text-fg">{API_KEY}</span>
			</div>
		</div>
		<h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.05] tracking-tight max-w-[24ch] text-balance">
			{m.start_title()}
		</h2>
		<p class="mt-4 text-sm md:text-base text-fg-muted max-w-[48ch] leading-relaxed">{m.start_lede()}</p>

		<div class="mt-12 overflow-hidden rounded-xl border border-border bg-bg-elevated/30 relative" data-quickstart-tabs role="tablist">
			{/* connector spine — vertical line through the rail badges (desktop only) */}
			<div class="hidden md:block absolute left-[calc(2.75rem+0.5px)] top-12 bottom-12 w-px bg-linear-to-b from-primary/60 via-primary/30 to-primary/10" aria-hidden="true"></div>

			{/* Step 01 — pick */}
			<div class="flex flex-col md:flex-row md:items-stretch border-b border-border">
				<div class="flex md:flex-col md:w-52 md:shrink-0 md:border-r border-b md:border-b-0 border-border md:p-5 px-5 py-3 gap-3 md:gap-3 items-baseline md:items-start bg-bg-elevated relative">
					<div class="flex items-center gap-2.5">
						<span class="relative z-10 inline-flex size-7 items-center justify-center bg-bg border border-primary text-primary font-mono text-[11px] tabular-nums shadow-[0_0_0_3px_var(--bg-elevated)]">01</span>
						<svg class="size-3.5 text-primary/70 hidden md:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={stepIcons.pick} />
					</div>
					<div class="flex flex-col gap-1">
						<div class="text-[11px] uppercase tracking-wider text-fg">Pick</div>
						<div class="hidden md:block text-[11.5px] text-fg-muted leading-relaxed">Choose the SDK that matches your runtime.</div>
					</div>
				</div>
				<div class="flex-1 p-5">
					<div class="flex flex-wrap gap-2">
						{snippets.map((s) => (
							<button
								type="button"
								role="tab"
								data-tab-trigger={s.id}
								data-filename={s.filename}
								aria-selected={s.id === defaultId ? "true" : "false"}
								class="group inline-flex items-center gap-2 font-mono text-[12px] pl-2 pr-3 py-1.5 rounded-md border transition-all aria-[selected=true]:border-primary aria-[selected=true]:text-fg aria-[selected=true]:bg-primary/10 aria-[selected=true]:shadow-[inset_0_0_0_1px_var(--primary)] aria-[selected=false]:border-border aria-[selected=false]:text-fg-muted hover:text-fg hover:border-fg-muted"
							>
								<svg
									class="size-4 transition-opacity group-aria-[selected=false]:opacity-60"
									viewBox="0 0 24 24"
									fill={SDK_LOGOS[s.id]?.color ?? "currentColor"}
									aria-hidden="true"
									set:html={`<path d="${SDK_LOGOS[s.id]?.path ?? ""}"/>`}
								/>
								{s.label}
							</button>
						))}
					</div>
				</div>
			</div>

			{/* Step 02 — install */}
			<div class="flex flex-col md:flex-row md:items-stretch border-b border-border">
				<div class="flex md:flex-col md:w-52 md:shrink-0 md:border-r border-b md:border-b-0 border-border md:p-5 px-5 py-3 gap-3 md:gap-3 items-baseline md:items-start bg-bg-elevated relative">
					<div class="flex items-center gap-2.5">
						<span class="relative z-10 inline-flex size-7 items-center justify-center bg-bg border border-primary text-primary font-mono text-[11px] tabular-nums shadow-[0_0_0_3px_var(--bg-elevated)]">02</span>
						<svg class="size-3.5 text-primary/70 hidden md:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={stepIcons.install} />
					</div>
					<div class="flex flex-col gap-1">
						<div class="text-[11px] uppercase tracking-wider text-fg">Install</div>
						<div class="hidden md:block text-[11.5px] text-fg-muted leading-relaxed">Add the OpenTelemetry packages to your project.</div>
					</div>
				</div>
				<div class="flex-1 min-w-0">
					<div class="flex items-center gap-2 border-b border-border px-5 h-9 bg-bg-deep/50">
						<span class="font-mono text-fg-muted text-[12px]">$</span>
						<span class="text-[10px] uppercase tracking-wider text-fg-muted font-sans">{m.start_install_label()}</span>
					</div>
					{snippets.map((s) => (
						<div data-tab-panel={`install-${s.id}`} hidden={s.id !== defaultId} class="quickstart-code">
							<Code code={s.install} lang={s.installLang} theme="vitesse-dark" />
						</div>
					))}
				</div>
			</div>

			{/* Step 03 — instrument */}
			<div class="flex flex-col md:flex-row md:items-stretch">
				<div class="flex md:flex-col md:w-52 md:shrink-0 md:border-r border-b md:border-b-0 border-border md:p-5 px-5 py-3 gap-3 md:gap-3 items-baseline md:items-start bg-bg-elevated relative">
					<div class="flex items-center gap-2.5">
						<span class="relative z-10 inline-flex size-7 items-center justify-center bg-bg border border-primary text-primary font-mono text-[11px] tabular-nums shadow-[0_0_0_3px_var(--bg-elevated)]">03</span>
						<svg class="size-3.5 text-primary/70 hidden md:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={stepIcons.instrument} />
					</div>
					<div class="flex flex-col gap-1">
						<div class="text-[11px] uppercase tracking-wider text-fg">Instrument</div>
						<div class="hidden md:block text-[11.5px] text-fg-muted leading-relaxed">Drop this snippet in. First trace lands in seconds.</div>
					</div>
				</div>
				<div class="flex-1 min-w-0">
					<div class="flex items-center justify-between border-b border-border px-5 h-9 bg-bg-deep/50">
						<div class="flex items-center gap-2 min-w-0">
							<svg class="size-3.5 text-fg-muted shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" data-quickstart-active-logo>
								<path d={SDK_LOGOS[defaultId]?.path ?? ""} />
							</svg>
							<div class="text-[12px] text-fg-muted font-mono truncate" data-quickstart-active-filename>{snippets.find(s => s.id === defaultId)?.filename}</div>
						</div>
						<button
							type="button"
							data-quickstart-copy
							data-copy-default={m.start_copy()}
							data-copy-active={m.start_copied()}
							class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-wider text-fg-muted hover:text-fg transition-colors shrink-0"
						>
							<svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="9" y="9" width="13" height="13" rx="2" />
								<path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
							</svg>
							<span data-quickstart-copy-label>{m.start_copy()}</span>
						</button>
					</div>
					{snippets.map((s) => (
						<div data-tab-panel={s.id} hidden={s.id !== defaultId} class="quickstart-code">
							<Code code={s.instrument} lang={s.lang} theme="vitesse-dark" />
							<span hidden data-copy-source={s.id}>{s.instrument}</span>
						</div>
					))}
				</div>
			</div>
		</div>

		<p class="mt-10 text-[12px] text-fg-muted max-w-[48ch] leading-relaxed">{m.start_footnote()}</p>
	</div>

	{/* ──────────────────────────────────────────────────────── */}
	{/* Bookend                                                 */}
	{/* ──────────────────────────────────────────────────────── */}
	<div class="relative overflow-hidden drenched-amber">
		<div class="relative mx-auto max-w-6xl px-6 py-24 md:py-32">
			<h2 class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.04] tracking-tight max-w-[24ch]">
				{m.cta_bookend_title()}
			</h2>
			<p class="mt-5 text-base md:text-lg max-w-[48ch] opacity-85 leading-relaxed">{m.cta_bookend_lede()}</p>
			<div class="mt-10 flex flex-wrap items-center gap-3">
				<a
					href="https://app.maple.dev"
					class="inline-flex items-center justify-center h-11 px-5 rounded-lg bg-foreground text-background text-sm font-medium hover:bg-foreground/90 transition-colors"
				>
					{m.cta_bookend_primary()}
				</a>
				<a
					href="https://github.com/Makisuo/maple"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center h-11 px-5 rounded-lg border border-current/40 text-sm font-medium hover:bg-current/10 transition-colors"
				>
					{m.cta_bookend_secondary()}
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	const tabRow = document.querySelector<HTMLElement>("[data-quickstart-tabs]");

	if (tabRow) {
		const root = tabRow;

		function setActive(id: string) {
			root.querySelectorAll<HTMLElement>("[data-tab-trigger]").forEach((btn) => {
				btn.setAttribute("aria-selected", btn.dataset.tabTrigger === id ? "true" : "false");
			});
			root.querySelectorAll<HTMLElement>("[data-tab-panel]").forEach((panel) => {
				const target = panel.dataset.tabPanel ?? "";
				// Install panels are tagged "install-<id>"; instrument panels use the bare id.
				panel.hidden = target !== id && target !== `install-${id}`;
			});
			const trigger = root.querySelector<HTMLElement>(`[data-tab-trigger="${id}"]`);
			root.querySelectorAll<HTMLElement>("[data-quickstart-active-filename]").forEach((el) => {
				el.textContent = trigger?.dataset.filename ?? trigger?.textContent ?? "";
			});
			const sourceLogo = trigger?.querySelector("svg");
			if (sourceLogo) {
				root.querySelectorAll<SVGElement>("[data-quickstart-active-logo]").forEach((el) => {
					el.innerHTML = sourceLogo.innerHTML;
				});
			}
		}

		root.addEventListener("click", (event) => {
			const target = event.target as HTMLElement | null;
			const trigger = target?.closest<HTMLElement>("[data-tab-trigger]");
			if (!trigger) return;
			const id = trigger.dataset.tabTrigger;
			if (id) setActive(id);
		});

		const copyButton = root.querySelector<HTMLButtonElement>("[data-quickstart-copy]");
		const copyLabel = copyButton?.querySelector<HTMLElement>("[data-quickstart-copy-label]");
		copyButton?.addEventListener("click", () => {
			// Copy the source whose tab-panel is currently visible.
			const source = Array.from(root.querySelectorAll<HTMLElement>("[data-copy-source]")).find((el) => {
				const panel = el.closest<HTMLElement>("[data-tab-panel]");
				return panel ? !panel.hidden : true;
			});
			if (!source || !copyLabel) return;

			const text = source.textContent ?? "";
			const done = () => {
				const active = copyButton.dataset.copyActive ?? "Copied";
				const original = copyButton.dataset.copyDefault ?? "Copy";
				copyLabel.textContent = active;
				window.setTimeout(() => {
					copyLabel.textContent = original;
				}, 1500);
			};

			if (navigator.clipboard?.writeText) {
				navigator.clipboard.writeText(text).then(done).catch(() => done());
			} else {
				done();
			}
		});
	}
</script>

