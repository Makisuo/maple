---
/**
 * Tabbed SDK snippet showcase + bookend CTA.
 * Snippets mirror apps/web/src/components/quick-start/sdk-snippets.ts so the
 * landing page shows the same code the dashboard generates after sign-up.
 * Placeholder values: INGEST_URL = https://ingest.maple.dev, API_KEY = maple_pk_••••••••.
 */
import * as m from "../paraglide/messages";
import { Code } from "astro:components";

const INGEST_URL = "https://ingest.maple.dev";
const API_KEY = "maple_pk_••••••••";

type SnippetLang = "ts" | "python" | "go" | "bash";

type Snippet = {
	id: string;
	label: string;
	filename: string;
	descriptor: string;
	lang: SnippetLang;
	installLang: SnippetLang;
	install: string;
	instrument: string;
};

const fill = (s: string) => s.replaceAll("{{INGEST_URL}}", INGEST_URL).replaceAll("{{API_KEY}}", API_KEY);

// SDK brand logo SVG paths (from simpleicons.org, MIT licensed, monochrome)
