	.quickstart-code .astro-code {
		background-color: var(--bg-deep) !important;
		font-size: 12.5px;
		line-height: 1.55;
		padding: 1rem 1.25rem;
		overflow-x: auto;
		font-family: inherit;
	}
	.quickstart-code .astro-code code {
		font-family: inherit;
	}
</style>
