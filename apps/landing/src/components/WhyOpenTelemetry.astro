---
import * as m from "../paraglide/messages";
---

<section class="py-24 md:py-32 bg-muted/10">
    <div class="mx-auto max-w-6xl px-6">
        <div class="mb-12">
            <span class="text-[11px] text-accent uppercase tracking-wider">{m.otel_badge()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg">{m.otel_heading()}</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-border border border-border">
            <!-- No vendor lock-in -->
            <div class="bg-bg p-6 md:p-8">
                <div class="mb-4">
                    <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        <rect x="3" y="11" width="18" height="11"/>
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.otel_vendor_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed">
                    {m.otel_vendor_desc()}
                </p>
            </div>

            <!-- Future-proof -->
            <div class="bg-bg p-6 md:p-8">
                <div class="mb-4">
                    <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.otel_future_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed">
                    {m.otel_future_desc()}
                </p>
            </div>

            <!-- Covers all signals -->
            <div class="bg-bg p-6 md:p-8">
                <div class="mb-4">
                    <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.otel_signals_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed">
                    {m.otel_signals_desc()}
                </p>
            </div>

            <!-- Community-driven -->
            <div class="bg-bg p-6 md:p-8">
                <div class="mb-4">
                    <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.otel_community_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed">
                    {m.otel_community_desc()}
                </p>
            </div>
        </div>
    </div>
</section>
