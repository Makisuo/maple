---
import * as m from "../paraglide/messages";
---

<section id="how-it-works" class="py-16 md:py-24 lg:py-32 scroll-mt-24">
    <div class="mx-auto max-w-6xl px-6">
        <div class="mb-12">
            <span class="text-[11px] text-accent uppercase tracking-wider">{m.how_badge()}</span>
            <h2 class="mt-3 font-display text-2xl md:text-3xl font-bold text-fg tracking-tight">{m.how_heading()}</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border">
            <!-- Step 1: Instrument -->
            <div class="bg-bg p-5 md:p-8">
                <div class="text-[11px] text-accent font-medium mb-4">01</div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.how_step1_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed mb-6">
                    {m.how_step1_desc()}
                </p>
                <div class="bg-bg-elevated border border-border p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <span class="text-[9px] text-fg-muted ml-2">terminal</span>
                    </div>
                    <code class="text-[11px] text-chart-1 block leading-relaxed">
                        <span class="text-fg-muted">$</span> npm install \<br />
                        &nbsp;&nbsp;@opentelemetry/sdk-node \<br />
                        &nbsp;&nbsp;@opentelemetry/auto-instrumentations-node
                    </code>
                </div>
            </div>

            <!-- Step 2: Send -->
            <div class="bg-bg p-5 md:p-8">
                <div class="text-[11px] text-accent font-medium mb-4">02</div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.how_step2_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed mb-6">
                    {m.how_step2_desc()}
                </p>
                <div class="bg-bg-elevated border border-border p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <span class="text-[9px] text-fg-muted ml-2">.env</span>
                    </div>
                    <code class="text-[11px] text-chart-3 block leading-relaxed break-all">
                        OTEL_EXPORTER_OTLP_ENDPOINT=<br />
                        &nbsp;&nbsp;https://ingest.maple.dev
                    </code>
                </div>
            </div>

            <!-- Step 3: Visualize -->
            <div class="bg-bg p-5 md:p-8">
                <div class="text-[11px] text-accent font-medium mb-4">03</div>
                <h3 class="text-base font-semibold text-fg mb-2">{m.how_step3_title()}</h3>
                <p class="text-sm text-fg-muted leading-relaxed mb-6">
                    {m.how_step3_desc()}
                </p>
                <div class="bg-bg-elevated border border-border p-4">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <div class="w-2 h-2 bg-border"></div>
                        <span class="text-[9px] text-fg-muted ml-2">browser</span>
                    </div>
                    <code class="text-[11px] text-chart-2 block leading-relaxed">
                        <span class="text-fg-muted">open</span> https://maple.dev/dashboard
                    </code>
                </div>
            </div>
        </div>
    </div>
</section>
