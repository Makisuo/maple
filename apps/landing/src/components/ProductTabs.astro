---
import AppMock from './AppMock.astro';
import * as m from "../paraglide/messages";
---

<section class="py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6">
        <div class="mb-12">
            <span class="text-[11px] text-accent uppercase tracking-wider">{m.product_badge()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg">{m.product_heading()}</h2>
            <p class="mt-3 text-sm text-fg-muted max-w-lg">
                {m.product_subtitle()}
            </p>
        </div>

        <AppMock />
    </div>
</section>
