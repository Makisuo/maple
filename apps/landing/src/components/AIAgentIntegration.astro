---
import * as m from "../paraglide/messages";
---

<section class="py-24 md:py-32 bg-muted/10">
    <div class="mx-auto max-w-6xl px-6">
        <div class="mb-12">
            <span class="text-[11px] text-accent uppercase tracking-wider">{m.ai_badge()}</span>
            <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg">{m.ai_heading()}</h2>
            <p class="mt-3 text-sm text-fg-muted max-w-xl leading-relaxed">
                {m.ai_desc()}
            </p>
        </div>

        <!-- Agent conversation mockup -->
        <div class="border border-border bg-bg-elevated overflow-hidden">
            <!-- Window chrome -->
            <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
                <div class="w-2 h-2 bg-border"></div>
                <div class="w-2 h-2 bg-border"></div>
                <div class="w-2 h-2 bg-border"></div>
                <span class="text-[9px] text-fg-muted ml-2">{m.ai_session()}</span>
            </div>

            <div class="p-4 md:p-6 space-y-4">
                <!-- Alert trigger -->
                <div class="flex items-start gap-3">
                    <div class="w-5 h-5 border border-destructive/30 bg-destructive/5 flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-3 h-3 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                    </div>
                    <div>
                        <span class="text-[10px] text-destructive font-medium">{m.ai_alert_triggered()}</span>
                        <p class="text-[10px] text-fg-muted mt-0.5">{m.ai_alert_threshold()}</p>
                    </div>
                </div>

                <!-- Agent message 1 -->
                <div class="pl-8">
                    <span class="text-[10px] text-accent font-medium">{m.ai_agent()}</span>
                    <p class="text-[10px] text-fg-muted mt-0.5">{m.ai_investigating()}</p>
                </div>

                <!-- Tool call: system_health -->
                <div class="pl-8">
                    <div class="inline-flex items-center gap-1.5 border border-chart-1/30 bg-chart-1/5 px-2 py-1">
                        <div class="w-1.5 h-1.5 bg-chart-1"></div>
                        <span class="text-[9px] text-chart-1 font-mono">system_health</span>
                    </div>
                    <!-- Result card -->
                    <div class="mt-2 border border-border bg-bg p-3 max-w-md">
                        <div class="grid grid-cols-3 gap-3">
                            <div>
                                <span class="text-[8px] text-fg-muted block">{m.ai_error_rate()}</span>
                                <span class="text-[11px] text-destructive font-mono font-medium">8.4%</span>
                            </div>
                            <div>
                                <span class="text-[8px] text-fg-muted block">{m.ai_p99_latency()}</span>
                                <span class="text-[11px] text-fg font-mono font-medium">2.1s</span>
                            </div>
                            <div>
                                <span class="text-[8px] text-fg-muted block">{m.ai_throughput()}</span>
                                <span class="text-[11px] text-fg font-mono font-medium">1.2K/s</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Agent message 2 -->
                <div class="pl-8">
                    <span class="text-[10px] text-accent font-medium">{m.ai_agent()}</span>
                    <p class="text-[10px] text-fg-muted mt-0.5">{m.ai_above_threshold()}</p>
                </div>

                <!-- Tool call: find_errors -->
                <div class="pl-8">
                    <div class="inline-flex items-center gap-1.5 border border-chart-2/30 bg-chart-2/5 px-2 py-1">
                        <div class="w-1.5 h-1.5 bg-chart-2"></div>
                        <span class="text-[9px] text-chart-2 font-mono">find_errors</span>
                    </div>
                    <!-- Result card -->
                    <div class="mt-2 border border-border bg-bg p-3 max-w-md">
                        <div class="space-y-2">
                            <div class="flex items-center justify-between">
                                <span class="text-[9px] text-fg font-mono">ConnectionTimeout</span>
                                <span class="text-[9px] text-destructive font-mono">142 hits</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[9px] text-fg-muted font-mono">NullReference</span>
                                <span class="text-[9px] text-fg-muted font-mono">3 hits</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Agent message 3 -->
                <div class="pl-8">
                    <span class="text-[10px] text-accent font-medium">{m.ai_agent()}</span>
                    <p class="text-[10px] text-fg-muted mt-0.5">{m.ai_inspecting()}</p>
                </div>

                <!-- Tool call: inspect_trace -->
                <div class="pl-8">
                    <div class="inline-flex items-center gap-1.5 border border-chart-3/30 bg-chart-3/5 px-2 py-1">
                        <div class="w-1.5 h-1.5 bg-chart-3"></div>
                        <span class="text-[9px] text-chart-3 font-mono">inspect_trace</span>
                    </div>
                    <!-- Result card: span tree -->
                    <div class="mt-2 border border-border bg-bg p-3 max-w-md">
                        <div class="space-y-1">
                            <div class="flex items-center gap-2">
                                <div class="w-24 h-1.5 bg-chart-1/60"></div>
                                <span class="text-[8px] text-fg-muted font-mono">GET /api/users</span>
                                <span class="text-[8px] text-fg-muted">1.8s</span>
                            </div>
                            <div class="flex items-center gap-2 pl-4">
                                <div class="w-20 h-1.5 bg-chart-2/60"></div>
                                <span class="text-[8px] text-fg-muted font-mono">auth.verify</span>
                                <span class="text-[8px] text-fg-muted">45ms</span>
                            </div>
                            <div class="flex items-center gap-2 pl-4">
                                <div class="w-16 h-1.5 bg-destructive"></div>
                                <span class="text-[8px] text-destructive font-mono">db.query</span>
                                <span class="text-[8px] text-destructive">timeout</span>
                            </div>
                        </div>
                        <div class="mt-2 pt-2 border-t border-border">
                            <span class="text-[8px] text-fg-muted">trace_id: </span>
                            <span class="text-[8px] text-accent font-mono">f7e8d9c0b1a2</span>
                        </div>
                    </div>
                </div>

                <!-- Agent conclusion -->
                <div class="pl-8 border-l-2 border-accent/30 ml-1.5">
                    <div class="pl-4">
                        <span class="text-[10px] text-accent font-medium">{m.ai_agent()}</span>
                        <p class="text-[10px] text-fg mt-1 leading-relaxed">
                            {m.ai_root_cause()}
                        </p>
                        <div class="mt-2 bg-bg border border-border p-2">
                            <code class="text-[9px] text-chart-1 block leading-relaxed">
                                <span class="text-fg-muted">// {m.ai_suggested_fix()}</span><br />
                                <span class="text-fg-muted">pool.max =</span> <span class="text-chart-2">20</span> <span class="text-fg-muted">→</span> <span class="text-chart-2">50</span><br />
                                <span class="text-fg-muted">pool.timeout =</span> <span class="text-chart-2">5000</span> <span class="text-fg-muted">→</span> <span class="text-chart-2">10000</span>
                            </code>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MCP tools grid -->
        <div class="mt-6 border border-border bg-bg-elevated p-4 md:p-6">
            <div class="flex items-center justify-between mb-4">
                <span class="text-[10px] text-fg font-medium">18 MCP tools available</span>
                <span class="text-[8px] text-fg-muted">read &amp; write capabilities</span>
            </div>
            <div class="flex flex-wrap gap-1.5">
                <span class="text-[8px] text-chart-1 font-mono px-2 py-0.5 border border-chart-1/20 bg-chart-1/5">system_health</span>
                <span class="text-[8px] text-chart-2 font-mono px-2 py-0.5 border border-chart-2/20 bg-chart-2/5">find_errors</span>
                <span class="text-[8px] text-chart-3 font-mono px-2 py-0.5 border border-chart-3/20 bg-chart-3/5">inspect_trace</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">search_traces</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">search_logs</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">service_overview</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">diagnose_service</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">find_slow_traces</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">error_detail</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">list_metrics</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">query_data</span>
                <span class="text-[8px] text-accent font-mono px-2 py-0.5 border border-accent/20 bg-accent/5">create_alert_rule</span>
                <span class="text-[8px] text-accent font-mono px-2 py-0.5 border border-accent/20 bg-accent/5">create_dashboard</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">get_dashboard</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">list_dashboards</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">list_alert_rules</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">list_alert_incidents</span>
                <span class="text-[8px] text-fg-muted font-mono px-2 py-0.5 border border-border">list_metrics</span>
            </div>
        </div>

        <!-- Compatible agents -->
        <div class="mt-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-border border border-border">
                <div class="bg-bg p-4 md:p-6 flex items-center gap-3">
                    <img src="https://cdn.brandfetch.io/idW5s392j1/w/400/h/400/theme/dark/icon.png" alt="Claude" class="w-6 h-6 shrink-0" />
                    <div>
                        <span class="text-[11px] text-fg font-medium">Claude Code</span>
                        <span class="text-[9px] text-fg-muted block">Anthropic</span>
                    </div>
                </div>
                <div class="bg-bg p-4 md:p-6 flex items-center gap-3">
                    <img src="https://cdn.brandfetch.io/ideKwS9dxx/w/400/h/400/theme/dark/icon.jpeg" alt="Cursor" class="w-6 h-6 shrink-0" />
                    <div>
                        <span class="text-[11px] text-fg font-medium">Cursor</span>
                        <span class="text-[9px] text-fg-muted block">AI Editor</span>
                    </div>
                </div>
                <div class="bg-bg p-4 md:p-6 flex items-center gap-3">
                    <div class="w-6 h-6 bg-[#00D47E]/10 border border-[#00D47E]/20 flex items-center justify-center shrink-0">
                        <span class="text-[10px] text-[#00D47E] font-bold">W</span>
                    </div>
                    <div>
                        <span class="text-[11px] text-fg font-medium">Windsurf</span>
                        <span class="text-[9px] text-fg-muted block">AI Editor</span>
                    </div>
                </div>
                <div class="bg-bg p-4 md:p-6 flex items-center gap-3">
                    <div class="w-6 h-6 border border-border flex items-center justify-center shrink-0">
                        <span class="text-[10px] text-fg-muted font-bold">+</span>
                    </div>
                    <div>
                        <span class="text-[11px] text-fg font-medium">{m.ai_any_mcp()}</span>
                        <span class="text-[9px] text-fg-muted block">{m.ai_open_protocol()}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
