---
import * as m from "../paraglide/messages";
---

<section class="py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div>
                <span class="text-[11px] text-accent uppercase tracking-wider">{m.chat_badge()}</span>
                <h2 class="mt-3 text-2xl md:text-3xl font-bold text-fg">{m.chat_heading()}</h2>
                <p class="mt-3 text-sm text-fg-muted max-w-md leading-relaxed">
                    {m.chat_desc()}
                </p>
            </div>

            <!-- Chat mock -->
            <div class="border border-border bg-bg-elevated overflow-hidden">
                <!-- Window chrome with tabs -->
                <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
                    <div class="w-2 h-2 bg-border"></div>
                    <div class="w-2 h-2 bg-border"></div>
                    <div class="w-2 h-2 bg-border"></div>
                    <div class="flex items-center gap-1 ml-2">
                        <span class="text-[9px] text-fg bg-bg px-2 py-0.5 border border-border">Latency investigation</span>
                        <span class="text-[9px] text-fg-muted px-2 py-0.5">Error analysis</span>
                    </div>
                </div>

                <div class="p-4 md:p-6 space-y-4">
                    <!-- User message -->
                    <div class="flex items-start gap-3">
                        <div class="w-5 h-5 bg-fg/10 border border-border flex items-center justify-center shrink-0 mt-0.5">
                            <span class="text-[9px] text-fg-muted font-medium">Y</span>
                        </div>
                        <div>
                            <span class="text-[10px] text-fg font-medium">{m.chat_user_label()}</span>
                            <p class="text-[10px] text-fg-muted mt-0.5">{m.chat_user_msg()}</p>
                        </div>
                    </div>

                    <!-- Assistant response -->
                    <div class="flex items-start gap-3">
                        <div class="w-5 h-5 bg-accent/10 border border-accent/20 flex items-center justify-center shrink-0 mt-0.5">
                            <span class="text-[9px] text-accent font-bold">M</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <span class="text-[10px] text-accent font-medium">{m.chat_assistant_label()}</span>
                            <p class="text-[10px] text-fg-muted mt-1 leading-relaxed">
                                {m.chat_response_1()}
                            </p>

                            <!-- Inline metric cards -->
                            <div class="flex gap-2 mt-2">
                                <div class="border border-border bg-bg px-2 py-1">
                                    <span class="text-[8px] text-fg-muted block">P95 before</span>
                                    <span class="text-[10px] text-fg font-mono">140ms</span>
                                </div>
                                <div class="border border-destructive/30 bg-destructive/5 px-2 py-1">
                                    <span class="text-[8px] text-fg-muted block">P95 peak</span>
                                    <span class="text-[10px] text-destructive font-mono">890ms</span>
                                </div>
                            </div>

                            <p class="text-[10px] text-fg-muted mt-2 leading-relaxed">
                                {m.chat_response_2()}
                            </p>

                            <!-- Trace link -->
                            <div class="mt-2">
                                <span class="text-[9px] text-accent border border-accent/30 bg-accent/5 px-2 py-0.5 cursor-default inline-flex items-center gap-1">
                                    <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
                                    {m.chat_trace_link()}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
