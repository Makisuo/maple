---
/**
 * Hero — live waterfall as the centerpiece. No screenshot, no gradient text.
 * Sequence: small eyebrow badge → mono headline → terse subline → live
 * waterfall that ticks forward → CTAs anchor the act after the see.
 */
import LiveWaterfall from "./live/LiveWaterfall.astro";
import * as m from "../paraglide/messages";
---

<section class="relative pt-[68px] overflow-hidden">
	<!-- Soft top vignette -->
	<div class="absolute inset-0 pointer-events-none" style="
		background:
			radial-gradient(900px 480px at 50% -120px, color-mix(in oklab, var(--primary) 14%, transparent) 0%, transparent 70%),
			radial-gradient(600px 320px at 100% 110%, color-mix(in oklab, var(--primary) 6%, transparent) 0%, transparent 60%);
	"></div>

	<div class="relative mx-auto max-w-6xl px-6 pt-12 md:pt-16 pb-24 md:pb-28">
		<!-- Eyebrow -->
		<div class="mb-8 flex items-center gap-3 text-[10px] uppercase tracking-[0.18em] text-fg-muted">
			<span class="inline-flex items-center gap-2">
				<span class="inline-block size-1.5 rounded-full bg-primary animate-pulse-dot"></span>
				{m.hero_eyebrow()}
			</span>
			<span class="opacity-40">/</span>
			<span>{m.hero_eyebrow_2()}</span>
		</div>

		<!-- Headline -->
		<h1 class="font-display text-[44px] sm:text-6xl md:text-7xl lg:text-8xl font-semibold text-foreground leading-[0.98] tracking-[-0.02em] max-w-5xl">
			{m.hero_title()}
		</h1>

		<!-- Subtitle -->
		<p class="mt-7 text-base md:text-lg text-fg-muted max-w-2xl leading-relaxed">
			{m.hero_subtitle()}
		</p>

		<!-- Live waterfall -->
		<div class="mt-14 md:mt-16">
			<LiveWaterfall />
		</div>

		<!-- CTAs anchor the see-then-act sequence -->
		<div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3">
			<a href="https://app.maple.dev"
			   class="inline-flex items-center justify-center h-11 px-5 bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity">
				{m.cta_get_started()}
			</a>
			<a href="https://github.com/Makisuo/maple" target="_blank" rel="noopener noreferrer"
			   class="inline-flex items-center justify-center h-11 px-5 border border-border text-sm font-medium text-foreground hover:bg-bg-elevated transition-colors">
				{m.cta_github()}
			</a>
			<a href="#sovereignty" class="text-xs text-fg-muted hover:text-foreground transition-colors">
				{m.hero_keep_reading()}
			</a>
		</div>
	</div>
</section>
