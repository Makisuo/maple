---
import Layout from "../../layouts/Layout.astro"
import Nav from "../../components/Nav.astro"
import FeatureHero from "../../components/FeatureHero.astro"
import RoadmapBoard from "../../components/RoadmapBoard.astro"
import BottomCTA from "../../components/BottomCTA.astro"
import Footer from "../../components/Footer.astro"
import SeoHead from "../../components/SeoHead.astro"
import * as m from "../../paraglide/messages"

const pageTitle = m.page_roadmap_title()
const pageDescription = m.page_roadmap_desc()
---

<Layout title={pageTitle} description={pageDescription}>
	<SeoHead title={pageTitle} description={pageDescription} />
	<Nav />
	<FeatureHero
		label={m.page_roadmap_label()}
		title={m.page_roadmap_heading()}
		subtitle={m.page_roadmap_subtitle()}
	/>
	<RoadmapBoard />
	<BottomCTA />
	<Footer />
</Layout>
