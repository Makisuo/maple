{
  "name": "@maple/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./alerting": "./src/alerting.ts"
  },
  "scripts": {
    "db:migrate": "mkdir -p .data && bun run --cwd ../../packages/db db:migrate",
    "db:d1:migrations:sql": "bun run --cwd ../../packages/db db:d1:migrations:sql",
    "db:d1:export": "bun run --cwd ../../packages/db db:d1:export",
    "db:d1:import:sql": "bun run --cwd ../../packages/db db:d1:import:sql",
    "db:d1:prepare:local": "bun ./scripts/prepare-local-d1.ts",
    "deploy:stack": "alchemy-effect deploy",
    "destroy:stack": "alchemy-effect destroy",
    "dev": "bun run db:d1:prepare:local && wrangler dev --env-file ../../.env.local",
    "dev:bun": "bun run --env-file ../../.env.local --watch src/index.ts",
    "logs": "alchemy-effect logs",
    "start": "bun run --env-file ../../.env.local src/index.ts",
    "test": "bun test",
    "tail": "alchemy-effect tail",
    "typecheck": "tsc --noEmit",
    "tinybird:dev": "tinybird dev",
    "tinybird:build": "tinybird build",
    "tinybird:deploy": "tinybird deploy"
  },
  "dependencies": {
    "@clerk/backend": "^2.30.1",
    "@effect/opentelemetry": "catalog:effect",
    "@effect/platform-bun": "catalog:effect",
    "@libsql/client": "0.15.15",
    "@maple/db": "workspace:*",
    "@maple/domain": "workspace:*",
    "@maple/email": "workspace:*",
    "@maple/query-engine": "workspace:*",
    "@react-email/components": "^1.0.11",
    "@tinybirdco/sdk": "catalog:tinybird",
    "alchemy-effect": "^0.12.0",
    "autumn-js": "^1.2.5",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:effect",
    "@effect/platform-node": "4.0.0-beta.47",
    "@cloudflare/workers-types": "^4.20260405.0",
    "@types/bun": "^1.3.11",
    "@types/node": "catalog:tooling",
    "atmn": "^1.0.1",
    "typescript": "catalog:tooling",
    "wrangler": "^4.41.0"
  }
}
